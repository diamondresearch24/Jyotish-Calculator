  "verses": [
    {
      "id": "JP_12_5",
      "text": "सप्तमाधिपतिर्लग्ने स्त्रीजनकृतसंयोगः",
      "transliteration": "Saptamādhipatir lagne strījanakṛtasaṃyogaḥ",
      "translations": {
        "en": "When the lord of the 7th house occupies the Lagna, the native is closely linked with the spouse.",
        "hi": "सप्तमेश लग्न में हो तो जातक जीवनसाथी से गहरा संबंध रखता है।"
      },
      "source": {
        "text": "Jataka Parijata",
        "chapter": 12,
        "verse": 5,
        "alternativeReferences": []
      },
      "category": "marriage",
