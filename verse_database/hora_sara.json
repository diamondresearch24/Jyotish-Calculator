  "verses": [
    {
      "id": "HS_10_5",
      "text": "स्वोच्चे स्वराशौ वा ग्रहो दशायां शुभं फलं दद्यात्",
      "transliteration": "Svocce svarāśau vā graho daśāyāṃ śubhaṃ phalaṃ dadhyāt",
      "translations": {
        "en": "A planet gives auspicious results during its dasha when placed in exaltation or own sign.",
        "hi": "दशा में स्वराशि या उच्च का ग्रह शुभ फल देता है।"
      },
      "source": {
