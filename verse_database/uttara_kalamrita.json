  "verses": [
    {
      "id": "UK_4_5",
      "text": "लग्ने चन्द्रे शुभदृष्टौ सौम्यत्वं बुद्धिवर्धनम्",
      "transliteration": "Lagne candre śubhadṛṣṭau saumyatvaṃ buddhivardhanam",
      "translations": {
        "en": "Moon in Lagna with benefic aspects gives gentleness and enhanced intellect.",
        "hi": "लग्न में चंद्र शुभ दृष्टि में हो तो सौम्यता और बुद्धि-वृद्धि।"
      },
      "source": {
        "text": "Uttara Kalamrita",
        "chapter": 4,
        "verse": 5,
        "alternativeReferences": []
      },
