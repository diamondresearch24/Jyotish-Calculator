      "id": "PHALA_6_15_GAJAKESARI",
      "source": { "text": "Phaladeepika", "chapter": 6, "verse": 15 },
      "rule_type": "yoga",
      "conditions": { "yoga_key": "gajakesari", "planet": 4 },
      "exceptions": ["jupiter_debilitated", "moon_debilitated"],
