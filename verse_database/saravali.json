    {
      "id": "SARA_13_5",
      "text": "गुरौ नवमे धर्मं विद्यां पितृसौख्यं च",
      "transliteration": "Gurau navame dharmaṃ vidyāṃ pitṛsaukhyṃ ca",
      "translations": {
        "en": "Jupiter in 9th: righteousness, higher learning, fortune and happiness from father/guru.",
        "hi": "गुरु नवम में — धर्म, उच्च शिक्षा, भाग्य और पिता/गुरु से सुख।"
      },
      "source": { "text": "Saravali", "chapter": 13, "verse": 5, "alternativeReferences": [] },
      "category": "education",
      "subCategory": "planet_in_house",
      "applicability": { "conditions": ["jupiter_in_9th"], "exceptions": ["jupiter_debilitated", "jupiter_combust"] },
