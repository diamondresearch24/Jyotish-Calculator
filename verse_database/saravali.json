  "verses": [
    {
      "id": "SARA_9_5",
      "text": "मंगलेन्द्रः केन्द्रे वा त्रिकोणे रुचको योगः",
      "transliteration": "Maṅgalendraḥ kendre vā trikoṇe rucako yogaḥ",
      "translations": {
        "en": "When Mars is in kendra or trine, Ruchaka Yoga is formed",
        "hi": "मंगल के केंद्र या त्रिकोण में होने पर रुचक योग बनता है"
      },
      "source": {
        "text": "Saravali",
        "chapter": 9,
        "verse": 5,
        "alternativeReferences": []
      },
      "category": "yogas",
      "subCategory": "panchamahapurusha",
      "applicability": {
        "conditions": ["mars_kendra_trikona"],
        "exceptions": ["mars_debilitated", "mars_combust"]
      },
      "implementation": {
        "status": "implemented",
        "functionName": "detectYogas",
        "lastUpdated": "2026-07-11",
        "notes": "Implemented in detectYogas() as PMP yoga"
      },
      "crossReferences": [
        {
          "text": "BPHS",
          "chapter": 39,
          "verse": 8,
          "relationship": "similar"
        }
      ]
    },
    {
      "id": "SARA_9_6",
      "text": "बुधः केन्द्रे त्रिकोणे वा स्वोच्चे भद्रो योगः",
      "transliteration": "Budhaḥ kendre trikoṇe vā svocce bhadro yogaḥ",
      "translations": {
        "en": "Mercury in kendra or trine in own/exaltation/moolatrikona forms Bhadra Yoga.",
        "hi": "बुध केंद्र या त्रिकोण में स्व/उच्च/मूलत्रिकोण में हो तो भद्र योग बनता है।"
      },
      "source": { "text": "Saravali", "chapter": 9, "verse": 6, "alternativeReferences": [] },
      "category": "yogas",
      "subCategory": "panchamahapurusha",
      "applicability": { "conditions": ["mercury_kendra_trikona_dignity"], "exceptions": ["mercury_debilitated", "mercury_combust"] },
      "implementation": { "status": "implemented", "functionName": "detectYogas", "lastUpdated": "2026-07-14", "notes": "PMP yoga key pmp_bhadra" },
      "crossReferences": [{ "text": "BPHS", "chapter": 39, "verse": 8, "relationship": "similar" }]
    },
    {
      "id": "SARA_9_7",
      "text": "गुरुः केन्द्रे त्रिकोणे वा स्वोच्चे हंसो योगः",
      "transliteration": "Guruḥ kendre trikoṇe vā svocce haṃso yogaḥ",
      "translations": {
        "en": "Jupiter in kendra or trine in own/exaltation/moolatrikona forms Hamsa Yoga.",
        "hi": "गुरु केंद्र या त्रिकोण में स्व/उच्च/मूलत्रिकोण में हो तो हंस योग बनता है।"
      },
      "source": { "text": "Saravali", "chapter": 9, "verse": 7, "alternativeReferences": [] },
      "category": "yogas",
      "subCategory": "panchamahapurusha",
      "applicability": { "conditions": ["jupiter_kendra_trikona_dignity"], "exceptions": ["jupiter_debilitated", "jupiter_combust"] },
      "implementation": { "status": "implemented", "functionName": "detectYogas", "lastUpdated": "2026-07-14", "notes": "PMP yoga key pmp_hansa" },
      "crossReferences": [{ "text": "BPHS", "chapter": 39, "verse": 8, "relationship": "similar" }]
    },
    {
      "id": "SARA_13_1",
      "text": "सूर्ये दशमे पितृसौख्यं मानम्",
      "transliteration": "Sūrye daśame pitṛsaukhyṃ mānam",
      "translations": {
        "en": "Sun in 10th: honour from authority, success in government or leadership roles.",
        "hi": "सूर्य दशम में — सत्ता-सम्मान, सरकारी/नेतृत्व क्षेत्र में सफलता।"
      },
      "source": { "text": "Saravali", "chapter": 13, "verse": 1, "alternativeReferences": [] },
      "category": "career",
      "subCategory": "planet_in_house",
      "applicability": { "conditions": ["sun_in_10th"], "exceptions": ["sun_debilitated", "sun_combust"] },
      "implementation": { "status": "implemented", "functionName": "textRuleEvidence", "lastUpdated": "2026-07-14", "notes": "Wired via saravaliEvidence()" },
      "crossReferences": []
